# ── Marca / Nicho ─────────────────────────────────────────────
BRAND_NAME=MiMarca
NICHE=finanzas personales
BRAND_VOICE=Educativo, cercano y motivador. Usamos lenguaje claro y ejemplos prácticos.

# ── IA Local (Ollama) ──────────────────────────────────────────
# Instalar: https://ollama.ai
# Luego: ollama pull llama3
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_VISION_MODEL=llava

# ── TTS ────────────────────────────────────────────────────────
TTS_ENGINE=edge-tts
# Voces disponibles con edge-tts:
# es-MX-DaliaNeural (mujer México)
# es-MX-JorgeNeural (hombre México)
# es-ES-ElviraNeural (mujer España)
TTS_VOICE=es-MX-DaliaNeural

# ── APIs de medios gratuitos ───────────────────────────────────
# Registro gratuito en: https://www.pexels.com/api/
PEXELS_API_KEY=

# Registro gratuito en: https://pixabay.com/api/docs/
PIXABAY_API_KEY=

# ── Instagram (Meta Graph API) ─────────────────────────────────
# Requiere cuenta Business/Creator + Página de Facebook
# https://developers.facebook.com/docs/instagram-api
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=

# ── YouTube Data API v3 ────────────────────────────────────────
# Crear en Google Cloud Console
# https://console.cloud.google.com/
YOUTUBE_CLIENT_SECRETS=youtube_secrets.json

# ── Web ────────────────────────────────────────────────────────
WEB_HOST=127.0.0.1
WEB_PORT=8000
SECRET_KEY=cambia-esto-en-produccion

# ── Base de datos ──────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/db/social_ai.db
